{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/design": ["./src/design/index.ts"],
      "@/design/*": ["./src/design/*"],
      "@/components/*": ["./src/components/*"],
      "@/sections/*": ["./src/sections/*"],
      "@/features/*": ["./src/features/*"],
      "@/lab": ["./src/lab/index.ts"],
      "@/lab/*": ["./src/lab/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/fonts": ["./src/fonts/index.ts"],
      "@/fonts/*": ["./src/fonts/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "docs"]
}

